<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="var_stake">Stake</variable>
    <variable id="var_take_profit">Take Profit</variable>
    <variable id="var_stop_loss">Stop Loss</variable>
    <variable id="var_martingale">Martingale</variable>
    <variable id="var_win_stake">win-stake</variable>
    <variable id="var_s_state">strategy_state</variable>
    <variable id="var_sticky_count">Sticky_Runs_Remaining</variable>
    <variable id="var_e_found">entry_found</variable>
  </variables>
  <block type="trade_definition" id="blk_trade_def" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="blk_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ10V</field>
        <field name="VIRTUAL_HOOK">FALSE</field>
        <next>
          <block type="trade_definition_tradetype" id="blk_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">overunder</field>
            <next>
              <block type="trade_definition_contracttype" id="blk_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="blk_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="blk_restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="blk_restarterr" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="init_stake">
        <field name="VAR" id="var_stake">Stake</field>
        <value name="VALUE">
          <block type="math_number" id="init_stake_val">
            <field name="NUM">5</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="init_tp">
            <field name="VAR" id="var_take_profit">Take Profit</field>
            <value name="VALUE">
              <block type="math_number" id="init_tp_val">
                <field name="NUM">100</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="init_sl">
                <field name="VAR" id="var_stop_loss">Stop Loss</field>
                <value name="VALUE">
                  <block type="math_number" id="init_sl_val">
                    <field name="NUM">100</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="init_mart">
                    <field name="VAR" id="var_martingale">Martingale</field>
                    <value name="VALUE">
                      <block type="math_number" id="init_mart_val">
                        <field name="NUM">2</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="init_winstake">
                        <field name="VAR" id="var_win_stake">win-stake</field>
                        <value name="VALUE">
                          <block type="variables_get" id="get_stake_for_win">
                            <field name="VAR" id="var_stake">Stake</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="init_state">
                            <field name="VAR" id="var_s_state">strategy_state</field>
                            <value name="VALUE">
                              <block type="math_number" id="init_state_val">
                                <field name="NUM">0</field>
                              </block>
                            </value>
                            <next>
                              <block type="variables_set" id="init_sticky">
                                <field name="VAR" id="var_sticky_count">Sticky_Runs_Remaining</field>
                                <value name="VALUE">
                                  <block type="math_number" id="init_sticky_val">
                                    <field name="NUM">0</field>
                                  </block>
                                </value>
                                <next>
                                  <block type="variables_set" id="init_entry">
                                    <field name="VAR" id="var_e_found">entry_found</field>
                                    <value name="VALUE">
                                      <block type="logic_boolean" id="init_entry_true">
                                        <field name="BOOL">FALSE</field>
                                      </block>
                                    </value>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="blk_tradeoptions">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <shadow type="math_number_positive" id="dur_val">
            <field name="NUM">1</field>
          </shadow>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number_positive" id="amt_shadow">
            <field name="NUM">5</field>
          </shadow>
          <block type="variables_get" id="get_stake_amt">
            <field name="VAR" id="var_stake">Stake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <shadow type="math_number_positive" id="pred_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="logic_ternary" id="blk_pred_ternary">
            <value name="IF">
              <block type="logic_compare" id="blk_pred_state_check">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="get_state_pred">
                    <field name="VAR" id="var_s_state">strategy_state</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="pred_state0">
                    <field name="NUM">0</field>
                  </block>
                </value>
              </block>
            </value>
            <value name="THEN">
              <block type="math_number" id="pred_digit_1">
                <field name="NUM">1</field>
              </block>
            </value>
            <value name="ELSE">
              <block type="math_number" id="pred_digit_5">
                <field name="NUM">5</field>
              </block>
            </value>
          </block>
        </value>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="blk_before" deletable="false" x="0" y="800">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="controls_if" id="blk_entry_logic_root">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="variables_get" id="get_entry_val_direct">
            <field name="VAR" id="var_e_found">entry_found</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="controls_if" id="blk_buy_logic">
            <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="blk_buy_state_check">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="get_state_buy">
                    <field name="VAR" id="var_s_state">strategy_state</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="buy_state0_val">
                    <field name="NUM">0</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="purchase" id="blk_buy_over">
                <field name="PURCHASE_LIST">DIGITOVER</field>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="purchase" id="blk_buy_under">
                <field name="PURCHASE_LIST">DIGITUNDER</field>
              </block>
            </statement>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="controls_if" id="blk_scan_logic">
            <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="blk_is_state0_scan">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="get_state_scan">
                    <field name="VAR" id="var_s_state">strategy_state</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="state0_scan_val">
                    <field name="NUM">0</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="controls_if" id="blk_primary_cond">
                <value name="IF0">
                  <block type="last_digits_condition" id="blk_primary_digits">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" digit_input="true"></mutation>
                    <field name="CONDITION">LT</field>
                    <value name="DIGITS_COUNT">
                      <shadow type="math_number" id="primary_count">
                        <field name="NUM">5</field>
                      </shadow>
                    </value>
                    <value name="DIGIT">
                      <block type="math_number" id="primary_target">
                        <field name="NUM">2</field>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="variables_set" id="set_entry_true_p">
                    <field name="VAR" id="var_e_found">entry_found</field>
                    <value name="VALUE">
                      <block type="logic_boolean" id="entry_true_p_bool">
                        <field name="BOOL">TRUE</field>
                      </block>
                    </value>
                    <next>
                      <block type="notify" id="notify_entry_p">
                        <field name="NOTIFICATION_TYPE">success</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <shadow type="text" id="notify_entry_p_msg">
                            <field name="TEXT">Entry Found! (State 0)</field>
                          </shadow>
                        </value>
                      </block>
                    </next>
                  </block>
                </statement>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="controls_if" id="blk_shift_cond">
                <value name="IF0">
                  <block type="last_digits_condition" id="blk_shift_digits">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" digit_input="true"></mutation>
                    <field name="CONDITION">GT</field>
                    <value name="DIGITS_COUNT">
                      <shadow type="math_number" id="shift_count">
                        <field name="NUM">10</field>
                      </shadow>
                    </value>
                    <value name="DIGIT">
                      <block type="math_number" id="shift_target">
                        <field name="NUM">2</field>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="variables_set" id="set_entry_true_s">
                    <field name="VAR" id="var_e_found">entry_found</field>
                    <value name="VALUE">
                      <block type="logic_boolean" id="entry_true_s_bool">
                        <field name="BOOL">TRUE</field>
                      </block>
                    </value>
                    <next>
                      <block type="notify" id="notify_entry_s">
                        <field name="NOTIFICATION_TYPE">success</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <shadow type="text" id="notify_entry_s_msg">
                            <field name="TEXT">Entry Found! (State 1)</field>
                          </shadow>
                        </value>
                      </block>
                    </next>
                  </block>
                </statement>
              </block>
            </statement>
          </block>
        </statement>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="blk_after" deletable="false" x="800" y="60">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="blk_win_loss">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="blk_is_win">
            <field name="CHECK_RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="win_reset_stake">
            <field name="VAR" id="var_stake">Stake</field>
            <value name="VALUE">
              <block type="variables_get" id="get_win_stake">
                <field name="VAR" id="var_win_stake">win-stake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="win_reset_state">
                <field name="VAR" id="var_s_state">strategy_state</field>
                <value name="VALUE">
                  <block type="math_number" id="win_state_val">
                    <field name="NUM">0</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="win_set_entry">
                    <field name="VAR" id="var_e_found">entry_found</field>
                    <value name="VALUE">
                      <block type="logic_boolean" id="win_entry_true">
                        <field name="BOOL">TRUE</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="variables_set" id="loss_mart_stake">
            <field name="VAR" id="var_stake">Stake</field>
            <value name="VALUE">
              <block type="math_arithmetic" id="blk_calc_mart">
                <field name="OP">MULTIPLY</field>
                <value name="A">
                  <block type="variables_get" id="get_prev_stake">
                    <field name="VAR" id="var_stake">Stake</field>
                  </block>
                </value>
                <value name="B">
                  <block type="variables_get" id="get_mart_val">
                    <field name="VAR" id="var_martingale">Martingale</field>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <block type="variables_set" id="loss_shift_state">
                <field name="VAR" id="var_s_state">strategy_state</field>
                <value name="VALUE">
                  <block type="math_number" id="loss_state_val">
                    <field name="NUM">1</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="loss_clear_entry">
                    <field name="VAR" id="var_e_found">entry_found</field>
                    <value name="VALUE">
                      <block type="logic_boolean" id="loss_entry_false">
                        <field name="BOOL">FALSE</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="controls_if" id="blk_tp_sl_check">
            <mutation xmlns="http://www.w3.org/1999/xhtml" elseif="1" else="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="blk_tp_check">
                <field name="OP">GTE</field>
                <value name="A">
                  <block type="total_profit" id="blk_profit_tp"></block>
                </value>
                <value name="B">
                  <block type="variables_get" id="get_tp_val">
                    <field name="VAR" id="var_take_profit">Take Profit</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="text_print" id="blk_tp_msg">
                <value name="TEXT">
                  <shadow type="text" id="tp_shadow">
                    <field name="TEXT">Take Profit Reached!</field>
                  </shadow>
                </value>
              </block>
            </statement>
            <value name="IF1">
              <block type="logic_compare" id="blk_sl_check">
                <field name="OP">LTE</field>
                <value name="A">
                  <block type="total_profit" id="blk_profit_sl"></block>
                </value>
                <value name="B">
                  <block type="math_single" id="blk_neg_sl">
                    <field name="OP">NEG</field>
                    <value name="NUM">
                      <block type="variables_get" id="get_sl_val">
                        <field name="VAR" id="var_stop_loss">Stop Loss</field>
                      </block>
                    </value>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO1">
              <block type="text_print" id="blk_sl_msg">
                <value name="TEXT">
                  <shadow type="text" id="sl_shadow">
                    <field name="TEXT">Stop Loss Hit.</field>
                  </shadow>
                </value>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="trade_again" id="blk_trade_again"></block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
